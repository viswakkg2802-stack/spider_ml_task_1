# CONFIDENCE HISTOGRAM
# =====================================================

plt.figure(figsize=(8, 5))

plt.hist(
    normal_stats["confidences"],
    bins=30,
    alpha=0.5,
    label="Normal CE"
)

plt.hist(
    ls_stats["confidences"],
    bins=30,
