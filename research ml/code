# =====================================================

plt.subplot(1, 2, 2)

plt.plot(
    normal_hist["train_acc"],
    label="Normal Train"
)

plt.plot(
    normal_hist["val_acc"],
    label="Normal Val"
)

plt.plot(
    ls_hist["train_acc"],
    label="LS Train"
)

plt.plot(
    ls_hist["val_acc"],
    label="LS Val"
)

plt.title("Accuracy Comparison")
plt.xlabel("Epoch")
plt.ylabel("Accuracy (%)")
